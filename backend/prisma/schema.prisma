generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(uuid()) @db.VarChar(36)
  name                String               @db.VarChar(120)
  email               String               @unique
  phone               String?              @db.VarChar(30)
  address             String?              @db.VarChar(255)
  language            String?              @db.VarChar(30)
  gardeningExperience  String?              @db.VarChar(50)
  gardenSpaceType     String?              @db.VarChar(50)
  passwordHash        String               @db.VarChar(255)
  isActive              Boolean              @default(true)
  isEmailVerified       Boolean              @default(false)
  emailVerifiedAt       DateTime?
  lastLoginAt           DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  passwordResetTokens PasswordResetToken[]
  refreshTokens       RefreshToken[]
  userRoles           UserRole[]
  products            Product[]
  otpVerifications    OtpVerification[]
  inventoryMovements  InventoryMovement[]
  carts               Cart[]
  orders              Order[]
  orderStatusChanges  OrderStatusHistory[]
  assignedDeliveries  Delivery[]
  deliveryEvents      DeliveryEvent[]

  @@map("users")
}

model Role {
  id          String           @id @default(uuid()) @db.VarChar(36)
  name        String           @unique @db.VarChar(80)
  description String?          @db.VarChar(255)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  userRoles   UserRole[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @db.VarChar(36)
  name        String           @unique @db.VarChar(120)
  description String?          @db.VarChar(255)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roleLinks   RolePermission[]

  @@map("permissions")
}

model UserRole {
  id         String   @id @default(uuid()) @db.VarChar(36)
  userId     String   @db.VarChar(36)
  roleId     String   @db.VarChar(36)
  assignedAt DateTime @default(now())
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String     @id @default(uuid()) @db.VarChar(36)
  roleId       String     @db.VarChar(36)
  permissionId String     @db.VarChar(36)
  assignedAt   DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id           String    @id @default(uuid()) @db.VarChar(36)
  userId       String    @db.VarChar(36)
  tokenHash    String    @unique @db.VarChar(255)
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())
  createdByIp  String?   @db.VarChar(64)
  replacedById String?   @db.VarChar(36)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model ProductCategory {
  id          String     @id @default(uuid()) @db.VarChar(36)
  name        String     @db.VarChar(120)
  slug        String     @unique @db.VarChar(150)
  description String?    @db.Text
  imageUrl    String?    @db.VarChar(500)
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  products    Product[]

  @@index([slug])
  @@index([active])
  @@index([deletedAt])
  @@map("product_categories")
}

model Product {
  id               String             @id @default(uuid()) @db.VarChar(36)
  name             String             @db.VarChar(255)
  slug             String             @unique @db.VarChar(255)
  sku              String             @unique @db.VarChar(80)
  description      String?            @db.Text
  shortDescription String?            @db.VarChar(500)
  price            Decimal            @db.Decimal(10, 2)
  discountPrice    Decimal?           @db.Decimal(10, 2)
  currency         String             @default("RWF") @db.VarChar(3)
  categoryId       String             @db.VarChar(36)
  productType      String             @db.VarChar(50)
  imageUrl         String?            @db.VarChar(500)
  active           Boolean            @default(true)
  featured         Boolean            @default(false)
  stockStatus      String             @default("in_stock") @db.VarChar(30)
  careLevel        String?            @db.VarChar(50)
  lightRequirement String?            @db.VarChar(100)
  waterRequirement String?            @db.VarChar(100)
  soilType         String?            @db.VarChar(100)
  temperatureRange String?            @db.VarChar(100)
  growthSize       String?            @db.VarChar(100)
  color            String?            @db.VarChar(100)
  occasion         String?            @db.VarChar(100)
  tags             String?            @db.Text
  createdById      String             @db.VarChar(36)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?
  category         ProductCategory    @relation(fields: [categoryId], references: [id])
  createdBy        User               @relation(fields: [createdById], references: [id])
  images           ProductImage[]
  attributes       ProductAttribute[]
  stockLevels      StockLevel[]
  movements        InventoryMovement[]
  cartItems        CartItem[]
  orderItems       OrderItem[]

  @@index([slug])
  @@index([sku])
  @@index([categoryId])
  @@index([productType])
  @@index([active])
  @@index([featured])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(uuid()) @db.VarChar(36)
  productId String   @db.VarChar(36)
  url       String   @db.VarChar(500)
  alt       String?  @db.VarChar(255)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model ProductAttribute {
  id        String   @id @default(uuid()) @db.VarChar(36)
  productId String   @db.VarChar(36)
  name      String   @db.VarChar(100)
  value     String   @db.VarChar(255)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_attributes")
}

model OtpVerification {
  id        String    @id @default(uuid()) @db.VarChar(36)
  userId    String    @db.VarChar(36)
  email     String
  otpHash   String    @db.VarChar(255)
  purpose   String    @db.VarChar(30)
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email])
  @@index([purpose])
  @@index([expiresAt])
  @@map("otp_verifications")
}

model InventoryLocation {
  id          String              @id @default(uuid()) @db.VarChar(36)
  name        String              @db.VarChar(120)
  code        String              @unique @db.VarChar(50)
  description String?             @db.Text
  address     String?             @db.VarChar(255)
  active      Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deletedAt   DateTime?
  stockLevels StockLevel[]
  movements   InventoryMovement[]

  @@index([code])
  @@index([active])
  @@index([deletedAt])
  @@map("inventory_locations")
}

model StockLevel {
  id               String             @id @default(uuid()) @db.VarChar(36)
  productId        String             @db.VarChar(36)
  locationId       String             @db.VarChar(36)
  quantity         Int                @default(0)
  reservedQuantity Int                @default(0)
  lowStockThreshold Int               @default(10)
  reorderPoint     Int                @default(5)
  maxStockLevel    Int                @default(100)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  product          Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  location         InventoryLocation  @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([productId, locationId])
  @@index([productId])
  @@index([locationId])
  @@index([quantity])
  @@map("stock_levels")
}

model InventoryMovement {
  id              String             @id @default(uuid()) @db.VarChar(36)
  productId       String             @db.VarChar(36)
  locationId      String             @db.VarChar(36)
  movementType    String             @db.VarChar(30)
  quantity        Int
  previousQuantity Int
  newQuantity     Int
  reason          String             @db.VarChar(255)
  referenceType   String             @default("MANUAL") @db.VarChar(50)
  referenceId     String?            @db.VarChar(36)
  note            String?            @db.Text
  performedById   String             @db.VarChar(36)
  createdAt       DateTime           @default(now())
  product         Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  location        InventoryLocation  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  performedBy     User               @relation(fields: [performedById], references: [id])

  @@index([productId])
  @@index([locationId])
  @@index([movementType])
  @@index([performedById])
  @@index([createdAt])
  @@map("inventory_movements")
}

model Cart {
  id        String     @id @default(uuid()) @db.VarChar(36)
  userId    String     @db.VarChar(36)
  status    String     @default("ACTIVE") @db.VarChar(20)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@unique([userId, status])
  @@index([userId])
  @@index([status])
  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid()) @db.VarChar(36)
  cartId    String   @db.VarChar(36)
  productId String   @db.VarChar(36)
  quantity  Int      @default(1)
  unitPrice Decimal  @db.Decimal(10, 2)
  currency  String   @default("RWF") @db.VarChar(3)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
  @@map("cart_items")
}

model Order {
  id              String           @id @default(uuid()) @db.VarChar(36)
  orderNumber     String           @unique @db.VarChar(30)
  userId          String           @db.VarChar(36)
  status          String           @default("PENDING") @db.VarChar(30)
  paymentStatus   String           @default("PENDING") @db.VarChar(20)
  subtotal        Decimal          @db.Decimal(10, 2)
  deliveryFee     Decimal          @default(0) @db.Decimal(10, 2)
  discountAmount  Decimal          @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal          @db.Decimal(10, 2)
  currency        String           @default("RWF") @db.VarChar(3)
  shippingFullName  String         @db.VarChar(120)
  shippingPhone     String         @db.VarChar(30)
  shippingAddress   String         @db.VarChar(255)
  shippingCity      String         @db.VarChar(100)
  shippingDistrict  String         @db.VarChar(100)
  shippingNotes     String?        @db.VarChar(500)
  deliveryMethod    String         @db.VarChar(30)
  paymentMethod     String         @db.VarChar(30)
  cancelledAt       DateTime?
  cancelReason      String?        @db.VarChar(500)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id])
  items           OrderItem[]
  statusHistory   OrderStatusHistory[]
  delivery        Delivery?

  @@index([orderNumber])
  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("orders")
}

model Delivery {
  id                String           @id @default(uuid()) @db.VarChar(36)
  orderId           String           @unique @db.VarChar(36)
  assignedToId      String?          @db.VarChar(36)
  status            String           @default("PENDING_ASSIGNMENT") @db.VarChar(30)
  scheduledAt       DateTime?
  pickedUpAt        DateTime?
  deliveredAt       DateTime?
  failedAt          DateTime?
  deliveryAddress   String?          @db.VarChar(255)
  deliveryPhone     String?          @db.VarChar(30)
  deliveryNotes     String?          @db.VarChar(500)
  currentLocation   String?          @db.VarChar(255)
  proofOfDeliveryUrl String?         @db.VarChar(500)
  recipientName     String?          @db.VarChar(120)
  recipientSignature String?         @db.Text
  failureReason     String?          @db.VarChar(500)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  order             Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  assignedTo        User?            @relation(fields: [assignedToId], references: [id])
  events            DeliveryEvent[]

  @@index([orderId])
  @@index([assignedToId])
  @@index([status])
  @@map("deliveries")
}

model DeliveryEvent {
  id          String   @id @default(uuid()) @db.VarChar(36)
  deliveryId  String   @db.VarChar(36)
  status      String   @db.VarChar(30)
  note        String?  @db.VarChar(500)
  location    String?  @db.VarChar(255)
  createdById String   @db.VarChar(36)
  createdAt   DateTime @default(now())
  delivery    Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@index([deliveryId])
  @@index([createdById])
  @@map("delivery_events")
}

model OrderItem {
  id          String   @id @default(uuid()) @db.VarChar(36)
  orderId     String   @db.VarChar(36)
  productId   String   @db.VarChar(36)
  productName String   @db.VarChar(255)
  productSku  String   @db.VarChar(80)
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  subtotal    Decimal  @db.Decimal(10, 2)
  currency    String   @default("RWF") @db.VarChar(3)
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model OrderStatusHistory {
  id          String   @id @default(uuid()) @db.VarChar(36)
  orderId     String   @db.VarChar(36)
  status      String   @db.VarChar(30)
  note        String?  @db.VarChar(255)
  changedById String   @db.VarChar(36)
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedBy   User     @relation(fields: [changedById], references: [id])

  @@index([orderId])
  @@index([changedById])
  @@map("order_status_history")
}

model PasswordResetToken {
  id          String    @id @default(uuid()) @db.VarChar(36)
  userId      String    @db.VarChar(36)
  tokenHash   String    @unique @db.VarChar(255)
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  createdByIp String?   @db.VarChar(64)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}
