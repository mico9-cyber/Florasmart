generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(uuid()) @db.VarChar(36)
  name                String               @db.VarChar(120)
  email               String               @unique
  phone               String?              @db.VarChar(30)
  address             String?              @db.VarChar(255)
  language            String?              @db.VarChar(30)
  gardeningExperience  String?              @db.VarChar(50)
  gardenSpaceType     String?              @db.VarChar(50)
  passwordHash        String               @db.VarChar(255)
  isActive              Boolean              @default(true)
  isEmailVerified       Boolean              @default(false)
  emailVerifiedAt       DateTime?
  lastLoginAt           DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  passwordResetTokens PasswordResetToken[]
  refreshTokens       RefreshToken[]
  userRoles           UserRole[]
  products            Product[]
  otpVerifications    OtpVerification[]
  inventoryMovements  InventoryMovement[]
  carts               Cart[]
  orders              Order[]
  orderStatusChanges  OrderStatusHistory[]
  assignedDeliveries  Delivery[]
  deliveryEvents      DeliveryEvent[]
  gardenPlans         GardenPlan[]
  gardenNotes         GardenNote[]
  userPreference      UserPreference?
  recommendationRequests RecommendationRequest[]
  chatbotConversations  ChatbotConversation[]
  chatbotFeedback       ChatbotFeedback[]
  loyaltyAccount        LoyaltyAccount?
  loyaltyTransactions   LoyaltyTransaction[]
  rewardRedemptions     RewardRedemption[]
  userSubscriptions     UserSubscription[]
  reportJobs            ReportJob[]
  reportDownloads       ReportDownload[]
  notifications         Notification[]
  notificationPreference NotificationPreference?
  emailLogs             EmailLog[]
  customerConsultations  Consultation[] @relation("CustomerConsultations")
  gardenerConsultations  Consultation[] @relation("GardenerConsultations")

  @@map("users")
}

model Role {
  id          String           @id @default(uuid()) @db.VarChar(36)
  name        String           @unique @db.VarChar(80)
  description String?          @db.VarChar(255)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  userRoles   UserRole[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @db.VarChar(36)
  name        String           @unique @db.VarChar(120)
  description String?          @db.VarChar(255)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roleLinks   RolePermission[]

  @@map("permissions")
}

model UserRole {
  id         String   @id @default(uuid()) @db.VarChar(36)
  userId     String   @db.VarChar(36)
  roleId     String   @db.VarChar(36)
  assignedAt DateTime @default(now())
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String     @id @default(uuid()) @db.VarChar(36)
  roleId       String     @db.VarChar(36)
  permissionId String     @db.VarChar(36)
  assignedAt   DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id           String    @id @default(uuid()) @db.VarChar(36)
  userId       String    @db.VarChar(36)
  tokenHash    String    @unique @db.VarChar(255)
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())
  createdByIp  String?   @db.VarChar(64)
  replacedById String?   @db.VarChar(36)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model ProductCategory {
  id          String     @id @default(uuid()) @db.VarChar(36)
  name        String     @db.VarChar(120)
  slug        String     @unique @db.VarChar(150)
  description String?    @db.Text
  imageUrl    String?    @db.VarChar(500)
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  products    Product[]

  @@index([slug])
  @@index([active])
  @@index([deletedAt])
  @@map("product_categories")
}

model Product {
  id               String             @id @default(uuid()) @db.VarChar(36)
  name             String             @db.VarChar(255)
  slug             String             @unique @db.VarChar(255)
  sku              String             @unique @db.VarChar(80)
  description      String?            @db.Text
  shortDescription String?            @db.VarChar(500)
  price            Decimal            @db.Decimal(10, 2)
  discountPrice    Decimal?           @db.Decimal(10, 2)
  currency         String             @default("RWF") @db.VarChar(3)
  categoryId       String             @db.VarChar(36)
  productType      String             @db.VarChar(50)
  imageUrl         String?            @db.VarChar(500)
  active           Boolean            @default(true)
  featured         Boolean            @default(false)
  stockStatus      String             @default("in_stock") @db.VarChar(30)
  careLevel        String?            @db.VarChar(50)
  lightRequirement String?            @db.VarChar(100)
  waterRequirement String?            @db.VarChar(100)
  soilType         String?            @db.VarChar(100)
  temperatureRange String?            @db.VarChar(100)
  growthSize       String?            @db.VarChar(100)
  color            String?            @db.VarChar(100)
  occasion         String?            @db.VarChar(100)
  tags             String?            @db.Text
  createdById      String             @db.VarChar(36)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?
  category         ProductCategory    @relation(fields: [categoryId], references: [id])
  createdBy        User               @relation(fields: [createdById], references: [id])
  images           ProductImage[]
  attributes       ProductAttribute[]
  stockLevels      StockLevel[]
  movements        InventoryMovement[]
  cartItems        CartItem[]
  orderItems       OrderItem[]
  gardenPlacements      GardenPlantPlacement[]
  recommendationResults RecommendationResult[]

  @@index([slug])
  @@index([sku])
  @@index([categoryId])
  @@index([productType])
  @@index([active])
  @@index([featured])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(uuid()) @db.VarChar(36)
  productId String   @db.VarChar(36)
  url       String   @db.VarChar(500)
  alt       String?  @db.VarChar(255)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model ProductAttribute {
  id        String   @id @default(uuid()) @db.VarChar(36)
  productId String   @db.VarChar(36)
  name      String   @db.VarChar(100)
  value     String   @db.VarChar(255)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_attributes")
}

model OtpVerification {
  id        String    @id @default(uuid()) @db.VarChar(36)
  userId    String    @db.VarChar(36)
  email     String
  otpHash   String    @db.VarChar(255)
  purpose   String    @db.VarChar(30)
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email])
  @@index([purpose])
  @@index([expiresAt])
  @@map("otp_verifications")
}

model InventoryLocation {
  id          String              @id @default(uuid()) @db.VarChar(36)
  name        String              @db.VarChar(120)
  code        String              @unique @db.VarChar(50)
  description String?             @db.Text
  address     String?             @db.VarChar(255)
  active      Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deletedAt   DateTime?
  stockLevels StockLevel[]
  movements   InventoryMovement[]

  @@index([code])
  @@index([active])
  @@index([deletedAt])
  @@map("inventory_locations")
}

model StockLevel {
  id               String             @id @default(uuid()) @db.VarChar(36)
  productId        String             @db.VarChar(36)
  locationId       String             @db.VarChar(36)
  quantity         Int                @default(0)
  reservedQuantity Int                @default(0)
  lowStockThreshold Int               @default(10)
  reorderPoint     Int                @default(5)
  maxStockLevel    Int                @default(100)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  product          Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  location         InventoryLocation  @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([productId, locationId])
  @@index([productId])
  @@index([locationId])
  @@index([quantity])
  @@map("stock_levels")
}

model InventoryMovement {
  id              String             @id @default(uuid()) @db.VarChar(36)
  productId       String             @db.VarChar(36)
  locationId      String             @db.VarChar(36)
  movementType    String             @db.VarChar(30)
  quantity        Int
  previousQuantity Int
  newQuantity     Int
  reason          String             @db.VarChar(255)
  referenceType   String             @default("MANUAL") @db.VarChar(50)
  referenceId     String?            @db.VarChar(36)
  note            String?            @db.Text
  performedById   String             @db.VarChar(36)
  createdAt       DateTime           @default(now())
  product         Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  location        InventoryLocation  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  performedBy     User               @relation(fields: [performedById], references: [id])

  @@index([productId])
  @@index([locationId])
  @@index([movementType])
  @@index([performedById])
  @@index([createdAt])
  @@map("inventory_movements")
}

model Cart {
  id        String     @id @default(uuid()) @db.VarChar(36)
  userId    String     @db.VarChar(36)
  status    String     @default("ACTIVE") @db.VarChar(20)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@unique([userId, status])
  @@index([userId])
  @@index([status])
  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid()) @db.VarChar(36)
  cartId    String   @db.VarChar(36)
  productId String   @db.VarChar(36)
  quantity  Int      @default(1)
  unitPrice Decimal  @db.Decimal(10, 2)
  currency  String   @default("RWF") @db.VarChar(3)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
  @@map("cart_items")
}

model Order {
  id              String           @id @default(uuid()) @db.VarChar(36)
  orderNumber     String           @unique @db.VarChar(30)
  userId          String           @db.VarChar(36)
  status          String           @default("PENDING") @db.VarChar(30)
  paymentStatus   String           @default("PENDING") @db.VarChar(20)
  subtotal        Decimal          @db.Decimal(10, 2)
  deliveryFee     Decimal          @default(0) @db.Decimal(10, 2)
  discountAmount  Decimal          @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal          @db.Decimal(10, 2)
  currency        String           @default("RWF") @db.VarChar(3)
  shippingFullName  String         @db.VarChar(120)
  shippingPhone     String         @db.VarChar(30)
  shippingAddress   String         @db.VarChar(255)
  shippingCity      String         @db.VarChar(100)
  shippingDistrict  String         @db.VarChar(100)
  shippingNotes     String?        @db.VarChar(500)
  deliveryMethod    String         @db.VarChar(30)
  paymentMethod     String         @db.VarChar(30)
  cancelledAt       DateTime?
  cancelReason      String?        @db.VarChar(500)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id])
  items           OrderItem[]
  statusHistory   OrderStatusHistory[]
  delivery        Delivery?

  @@index([orderNumber])
  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("orders")
}

model Delivery {
  id                String           @id @default(uuid()) @db.VarChar(36)
  orderId           String           @unique @db.VarChar(36)
  assignedToId      String?          @db.VarChar(36)
  status            String           @default("PENDING_ASSIGNMENT") @db.VarChar(30)
  scheduledAt       DateTime?
  pickedUpAt        DateTime?
  deliveredAt       DateTime?
  failedAt          DateTime?
  deliveryAddress   String?          @db.VarChar(255)
  deliveryPhone     String?          @db.VarChar(30)
  deliveryNotes     String?          @db.VarChar(500)
  currentLocation   String?          @db.VarChar(255)
  proofOfDeliveryUrl String?         @db.VarChar(500)
  recipientName     String?          @db.VarChar(120)
  recipientSignature String?         @db.Text
  failureReason     String?          @db.VarChar(500)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  order             Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  assignedTo        User?            @relation(fields: [assignedToId], references: [id])
  events            DeliveryEvent[]

  @@index([orderId])
  @@index([assignedToId])
  @@index([status])
  @@map("deliveries")
}

model DeliveryEvent {
  id          String   @id @default(uuid()) @db.VarChar(36)
  deliveryId  String   @db.VarChar(36)
  status      String   @db.VarChar(30)
  note        String?  @db.VarChar(500)
  location    String?  @db.VarChar(255)
  createdById String   @db.VarChar(36)
  createdAt   DateTime @default(now())
  delivery    Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@index([deliveryId])
  @@index([createdById])
  @@map("delivery_events")
}

model OrderItem {
  id          String   @id @default(uuid()) @db.VarChar(36)
  orderId     String   @db.VarChar(36)
  productId   String   @db.VarChar(36)
  productName String   @db.VarChar(255)
  productSku  String   @db.VarChar(80)
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  subtotal    Decimal  @db.Decimal(10, 2)
  currency    String   @default("RWF") @db.VarChar(3)
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model OrderStatusHistory {
  id          String   @id @default(uuid()) @db.VarChar(36)
  orderId     String   @db.VarChar(36)
  status      String   @db.VarChar(30)
  note        String?  @db.VarChar(255)
  changedById String   @db.VarChar(36)
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedBy   User     @relation(fields: [changedById], references: [id])

  @@index([orderId])
  @@index([changedById])
  @@map("order_status_history")
}

model PasswordResetToken {
  id          String    @id @default(uuid()) @db.VarChar(36)
  userId      String    @db.VarChar(36)
  tokenHash   String    @unique @db.VarChar(255)
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  createdByIp String?   @db.VarChar(64)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model GardenPlan {
  id          String              @id @default(uuid()) @db.VarChar(36)
  userId      String              @db.VarChar(36)
  name        String              @db.VarChar(120)
  description String?             @db.VarChar(500)
  width       Int                 @default(10)
  height      Int                 @default(10)
  gridData    Json?
  isDefault   Boolean             @default(false)
  tags        String?             @db.Text
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deletedAt   DateTime?
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  cells       GardenCell[]
  placements  GardenPlantPlacement[]
  notes       GardenNote[]

  @@index([userId])
  @@index([deletedAt])
  @@map("garden_plans")
}

model GardenCell {
  id        String   @id @default(uuid()) @db.VarChar(36)
  planId    String   @db.VarChar(36)
  row       Int
  col       Int
  soilType  String?  @db.VarChar(100)
  sunExposure String? @db.VarChar(100)
  notes     String?  @db.VarChar(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  plan      GardenPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, row, col])
  @@index([planId])
  @@map("garden_cells")
}

model GardenPlantPlacement {
  id           String     @id @default(uuid()) @db.VarChar(36)
  planId       String     @db.VarChar(36)
  productId    String     @db.VarChar(36)
  row          Int
  col          Int
  quantity     Int        @default(1)
  notes        String?    @db.VarChar(500)
  plantedAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  plan         GardenPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id])

  @@unique([planId, productId, row, col])
  @@index([planId])
  @@index([productId])
  @@map("garden_plant_placements")
}

model GardenNote {
  id        String     @id @default(uuid()) @db.VarChar(36)
  planId    String     @db.VarChar(36)
  userId    String     @db.VarChar(36)
  title     String     @db.VarChar(200)
  content   String     @db.Text
  noteType  String     @default("general") @db.VarChar(50)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  plan      GardenPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id])

  @@index([planId])
  @@index([userId])
  @@map("garden_notes")
}

model UserPreference {
  id                  String   @id @default(uuid()) @db.VarChar(36)
  userId              String   @unique @db.VarChar(36)
  sunlightLevel       String?  @db.VarChar(100)
  wateringLevel       String?  @db.VarChar(100)
  petSafeRequired     Boolean  @default(false)
  purpose             String?  @db.VarChar(100)
  experienceLevel     String?  @db.VarChar(50)
  spaceType           String?  @db.VarChar(50)
  preferredCategories String?  @db.Text
  preferredColors     String?  @db.VarChar(255)
  budgetMin           Decimal? @db.Decimal(10, 2)
  budgetMax           Decimal? @db.Decimal(10, 2)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_preferences")
}

model RecommendationRequest {
  id        String                  @id @default(uuid()) @db.VarChar(36)
  userId    String                  @db.VarChar(36)
  type      String                  @db.VarChar(50)
  inputData Json?
  createdAt DateTime                @default(now())
  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  results   RecommendationResult[]

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("recommendation_requests")
}

model RecommendationResult {
  id        String                @id @default(uuid()) @db.VarChar(36)
  requestId String                @db.VarChar(36)
  productId String                @db.VarChar(36)
  score     Int                   @default(0)
  reasons   Json?
  careNotes Json?
  warnings  Json?
  rank      Int                   @default(0)
  createdAt DateTime              @default(now())
  request   RecommendationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  product   Product               @relation(fields: [productId], references: [id])

  @@index([requestId])
  @@index([productId])
  @@index([score])
  @@map("recommendation_results")
}

model ChatbotConversation {
  id          String             @id @default(uuid()) @db.VarChar(36)
  userId      String             @db.VarChar(36)
  title       String?            @db.VarChar(200)
  status      String             @default("ACTIVE") @db.VarChar(20)
  contextType String?            @db.VarChar(50)
  contextId   String?            @db.VarChar(36)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  archivedAt  DateTime?
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    ChatbotMessage[]
  feedback    ChatbotFeedback[]

  @@index([userId])
  @@index([status])
  @@index([contextType])
  @@index([createdAt])
  @@map("chatbot_conversations")
}

model ChatbotMessage {
  id             String              @id @default(uuid()) @db.VarChar(36)
  conversationId String              @db.VarChar(36)
  sender         String              @db.VarChar(10)
  message        String              @db.Text
  intent         String?             @db.VarChar(50)
  responseType   String?             @db.VarChar(50)
  metadata       Json?
  createdAt      DateTime            @default(now())
  conversation   ChatbotConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  feedback       ChatbotFeedback[]

  @@index([conversationId])
  @@index([sender])
  @@map("chatbot_messages")
}

model ChatbotFeedback {
  id             String            @id @default(uuid()) @db.VarChar(36)
  conversationId String            @db.VarChar(36)
  messageId      String            @db.VarChar(36)
  userId         String            @db.VarChar(36)
  rating         String            @db.VarChar(20)
  comment        String?           @db.VarChar(500)
  createdAt      DateTime          @default(now())
  conversation   ChatbotConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message        ChatbotMessage    @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([messageId])
  @@index([userId])
  @@map("chatbot_feedback")
}

model ChatbotKnowledgeBase {
  id        String    @id @default(uuid()) @db.VarChar(36)
  title     String    @db.VarChar(200)
  category  String    @db.VarChar(50)
  keywords  String?   @db.Text
  question  String    @db.Text
  answer    String    @db.Text
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([category])
  @@index([active])
  @@map("chatbot_knowledge_base")
}

model LoyaltyAccount {
  id             String              @id @default(uuid()) @db.VarChar(36)
  userId         String              @unique @db.VarChar(36)
  pointsBalance  Int                 @default(0)
  lifetimePoints Int                 @default(0)
  tier           String              @default("BRONZE") @db.VarChar(20)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   LoyaltyTransaction[]
  redemptions    RewardRedemption[]

  @@index([userId])
  @@index([tier])
  @@map("loyalty_accounts")
}

model LoyaltyTransaction {
  id               String          @id @default(uuid()) @db.VarChar(36)
  loyaltyAccountId String          @db.VarChar(36)
  userId           String          @db.VarChar(36)
  type             String          @db.VarChar(20)
  points           Int
  balanceAfter     Int
  reason           String?         @db.VarChar(255)
  referenceType    String?         @db.VarChar(50)
  referenceId      String?         @db.VarChar(36)
  createdAt        DateTime        @default(now())
  loyaltyAccount   LoyaltyAccount  @relation(fields: [loyaltyAccountId], references: [id], onDelete: Cascade)
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([loyaltyAccountId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("loyalty_transactions")
}

model LoyaltyReward {
  id                String              @id @default(uuid()) @db.VarChar(36)
  name              String              @db.VarChar(200)
  description       String?             @db.VarChar(500)
  pointsCost        Int
  discountType      String              @db.VarChar(30)
  discountValue     Decimal?            @db.Decimal(10, 2)
  minimumOrderAmount Decimal?           @db.Decimal(10, 2)
  active            Boolean             @default(true)
  expiresAt         DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?
  redemptions       RewardRedemption[]

  @@index([active])
  @@index([deletedAt])
  @@map("loyalty_rewards")
}

model RewardRedemption {
  id               String          @id @default(uuid()) @db.VarChar(36)
  userId           String          @db.VarChar(36)
  loyaltyAccountId String          @db.VarChar(36)
  rewardId         String          @db.VarChar(36)
  couponCode       String          @unique @db.VarChar(50)
  status           String          @default("ACTIVE") @db.VarChar(20)
  redeemedAt       DateTime        @default(now())
  usedAt           DateTime?
  expiresAt        DateTime?
  orderId          String?         @db.VarChar(36)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  loyaltyAccount   LoyaltyAccount  @relation(fields: [loyaltyAccountId], references: [id], onDelete: Cascade)
  reward           LoyaltyReward   @relation(fields: [rewardId], references: [id])

  @@index([userId])
  @@index([loyaltyAccountId])
  @@index([rewardId])
  @@index([couponCode])
  @@index([status])
  @@map("reward_redemptions")
}

model SubscriptionPlan {
  id            String             @id @default(uuid()) @db.VarChar(36)
  name          String             @db.VarChar(200)
  description   String?            @db.VarChar(500)
  price         Decimal            @db.Decimal(10, 2)
  currency      String             @default("RWF") @db.VarChar(3)
  billingCycle  String             @db.VarChar(20)
  benefits      Json?
  active        Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?
  subscriptions UserSubscription[]

  @@index([active])
  @@index([deletedAt])
  @@map("subscription_plans")
}

model UserSubscription {
  id                String             @id @default(uuid()) @db.VarChar(36)
  userId            String             @db.VarChar(36)
  planId            String             @db.VarChar(36)
  status            String             @default("ACTIVE") @db.VarChar(20)
  startedAt         DateTime           @default(now())
  currentPeriodStart DateTime          @default(now())
  currentPeriodEnd  DateTime
  cancelledAt       DateTime?
  cancelReason      String?            @db.VarChar(500)
  autoRenew         Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan              SubscriptionPlan   @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([planId])
  @@index([status])
  @@map("user_subscriptions")
}

model ReportJob {
  id            String          @id @default(uuid()) @db.VarChar(36)
  requestedById String          @db.VarChar(36)
  reportType    String          @db.VarChar(50)
  format        String          @db.VarChar(10)
  status        String          @default("PENDING") @db.VarChar(20)
  filters       Json?
  filePath      String?         @db.VarChar(500)
  fileName      String?         @db.VarChar(255)
  fileSize      Int?
  errorMessage  String?         @db.VarChar(500)
  generatedAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  requestedBy   User            @relation(fields: [requestedById], references: [id], onDelete: Cascade)
  downloads     ReportDownload[]

  @@index([requestedById])
  @@index([reportType])
  @@index([status])
  @@index([createdAt])
  @@map("report_jobs")
}

model ReportDownload {
  id              String    @id @default(uuid()) @db.VarChar(36)
  reportJobId     String    @db.VarChar(36)
  downloadedById  String    @db.VarChar(36)
  downloadedAt    DateTime  @default(now())
  ipAddress       String?   @db.VarChar(64)
  userAgent       String?   @db.VarChar(500)
  reportJob       ReportJob @relation(fields: [reportJobId], references: [id], onDelete: Cascade)
  downloadedBy    User      @relation(fields: [downloadedById], references: [id], onDelete: Cascade)

  @@index([reportJobId])
  @@index([downloadedById])
  @@map("report_downloads")
}

model Notification {
  id        String    @id @default(uuid()) @db.VarChar(36)
  userId    String    @db.VarChar(36)
  type      String    @db.VarChar(50)
  channel   String    @default("IN_APP") @db.VarChar(20)
  title     String    @db.VarChar(255)
  message   String?   @db.Text
  data      Json?
  readAt    DateTime?
  sentAt    DateTime  @default(now())
  status    String    @default("SENT") @db.VarChar(20)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([channel])
  @@index([status])
  @@index([readAt])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id                 String   @id @default(uuid()) @db.VarChar(36)
  userId             String   @unique @db.VarChar(36)
  emailEnabled       Boolean  @default(true)
  inAppEnabled       Boolean  @default(true)
  orderUpdates       Boolean  @default(true)
  deliveryUpdates    Boolean  @default(true)
  inventoryAlerts    Boolean  @default(true)
  loyaltyUpdates     Boolean  @default(true)
  subscriptionUpdates Boolean @default(true)
  gardenReminders    Boolean  @default(true)
  marketingEmails    Boolean  @default(false)
  securityAlerts     Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notification_preferences")
}

model EmailLog {
  id                String    @id @default(uuid()) @db.VarChar(36)
  userId            String?   @db.VarChar(36)
  toEmail           String
  subject           String    @db.VarChar(255)
  templateName      String    @db.VarChar(100)
  status            String    @default("PENDING") @db.VarChar(20)
  errorMessage      String?   @db.VarChar(500)
  providerMessageId String?   @db.VarChar(255)
  metadata          Json?
  sentAt            DateTime?
  createdAt         DateTime  @default(now())
  user              User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([toEmail])
  @@index([status])
  @@index([templateName])
  @@index([createdAt])
  @@map("email_logs")
}

model NotificationTemplate {
  id        String   @id @default(uuid()) @db.VarChar(36)
  name      String   @unique @db.VarChar(100)
  subject   String   @db.VarChar(255)
  body      String   @db.Text
  type      String   @default("EMAIL") @db.VarChar(20)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([active])
  @@map("notification_templates")
}

model Consultation {
  id             String   @id @default(uuid()) @db.VarChar(36)
  customerId     String   @db.VarChar(36)
  gardenerId     String?  @db.VarChar(36)
  purpose        String   @db.VarChar(500)
  scheduledDate  DateTime @db.DateTime
  status         String   @default("PENDING") @db.VarChar(20)
  rejectedReason String?   @db.VarChar(500)
  rescheduledDate DateTime? @db.DateTime
  customer       User      @relation("CustomerConsultations", fields: [customerId], references: [id], onDelete: Cascade)
  gardener       User?    @relation("GardenerConsultations", fields: [gardenerId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  @@index([customerId])
  @@index([gardenerId])
  @@index([status])
  @@map("consultations")
}
