{
  "name": "florasmart-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node src/server.js",
    "start": "node src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "postinstall": "prisma generate",
    "seed": "prisma db seed",
    "start:with-db": "prisma generate && prisma migrate dev --name init && npm run seed && node src/server.js"
  },
  "dependencies": {
    "@prisma/client": "^6.14.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.1",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^7.0.5",
    "prisma": "^6.14.0",
    "uuid": "^11.1.0",
    "winston": "^3.17.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
